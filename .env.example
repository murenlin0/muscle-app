# 複製為 .env.local 後填入真實值（勿提交 .env.local）

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_DEV_LINE_USER_ID=dev-local-user-001
# LINE Developers → LIFF 詳情頁的 LIFF ID（含後綴，例 2010287240-NblkictG）
NEXT_PUBLIC_LIFF_ID_STORE1=
NEXT_PUBLIC_LIFF_ID_STORE2=
# 官方帳號 Basic ID（例 440fmgpo 或 @440fmgpo），用於 oaMessage 預填
NEXT_PUBLIC_LINE_OA_BASIC_ID_STORE1=
NEXT_PUBLIC_LINE_OA_BASIC_ID_STORE2=

PORTAL_SESSION_SECRET=change-me-local-dev-only
ADMIN_IMPORT_SECRET=change-me-local-dev-only

NOTION_API_KEY=

# Google Gemini（師傅預約訊息 AI 解析，免費層：https://aistudio.google.com/apikey）
# 2026 起 AI Studio 新金鑰為 AQ. 開頭（舊版 AIzaSy 仍可用）
GEMINI_API_KEY=
# 選填，預設 gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_OAUTH_SETUP_KEY=change-me
GOOGLE_CALENDAR_ID=muscle.com.tw@gmail.com
GOOGLE_REFRESH_TOKEN=

# Vercel Cron 自動日曆同步（/api/cron/calendar-sync）
CRON_SECRET=change-me-cron-secret
# 選填：回溯小時數，預設 72
CALENDAR_SYNC_LOOKBACK_HOURS=72
# 正式站網址（Google webhook 必須用 https 公開網域）
APP_BASE_URL=https://muscle.com.tw

# 本機 LIFF 用 ngrok 時設定（換隧道要改並重啟 dev）
NGROK_HOST=
